<h1>Fila de Carregamento</h1>

<p>Logado como <strong><%= current_user.name %></strong> (<%= current_user.email %>)</p>
<p>Papéis: <%= current_user.roles.map(&:name).join(", ").presence || "nenhum" %></p>

<% if current_user.admin? || current_user.role?(:cadastro) %>
  <nav>
    <%= link_to "Motoristas", cadastro_drivers_path %>
    <%= link_to "Caminhões", cadastro_trucks_path %>
  </nav>
<% end %>

<%= button_to "Sair", destroy_user_session_path, method: :delete %>
