<h1>Fila de Carregamento</h1>

<p>Logado como <strong><%= current_user.name %></strong> (<%= current_user.email %>)</p>
<p>Papéis: <%= current_user.roles.map(&:name).join(", ").presence || "nenhum" %></p>

<% if current_user.admin? || current_user.role?(:registration_operator) %>
  <nav>
    <%= link_to "Motoristas", registration_drivers_path %>
    <%= link_to "Caminhões", registration_trucks_path %>
    <%= link_to "Check-in no pátio", registration_visits_path %>
  </nav>
<% end %>

<%= button_to "Sair", destroy_user_session_path, method: :delete %>
