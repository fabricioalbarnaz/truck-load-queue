<h1>Caminhões</h1>

<p><%= link_to "Novo caminhão", new_registration_truck_path %></p>

<table>
  <thead>
    <tr>
      <th>Placa</th>
      <th>Modelo</th>
      <th>Capacidade</th>
      <th>Ativo</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @trucks.each do |truck| %>
      <tr>
        <td><%= link_to truck.plate, registration_truck_path(truck) %></td>
        <td><%= truck.model %></td>
        <td><%= truck.capacity %></td>
        <td><%= truck.active? ? "Sim" : "Não" %></td>
        <td>
          <%= link_to "Editar", edit_registration_truck_path(truck) %>
          <%= button_to "Remover", registration_truck_path(truck), method: :delete, class: "btn-danger", form: { data: { turbo_confirm: "Remover este caminhão?" } } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
