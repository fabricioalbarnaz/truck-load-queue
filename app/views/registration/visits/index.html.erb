<h1>Check-in no pátio</h1>

<%= form_with model: @visit, url: registration_visits_path do |form| %>
  <%= render "shared/errors", record: @visit, action_label: "check-in" %>

  <fieldset>
    <legend>Motorista</legend>
    <p>Informe o CPF: se já estiver cadastrado, os demais dados serão carregados automaticamente.</p>
    <%= render "shared/errors", record: @driver, action_label: "cadastro do motorista" %>
    <div data-controller="lookup"
         data-lookup-url-value="<%= lookup_registration_drivers_path %>"
         data-lookup-param-value="cpf">
      <%= form.fields_for :driver, @driver do |fd| %>
        <div>
          <%= fd.label :cpf, "CPF" %>
          <%= fd.text_field :cpf, data: { lookup_target: "query", action: "blur->lookup#lookup" } %>
          <span class="spinner" data-lookup-target="spinner" hidden></span>
        </div>

        <div>
          <%= fd.label :name, "Nome" %>
          <%= fd.text_field :name, data: { lookup_target: "fillable", lookup_field: "name" } %>
        </div>

        <div>
          <%= fd.label :phone, "Telefone (E.164, ex: +5511999999999)" %>
          <%= fd.text_field :phone, data: { lookup_target: "fillable", lookup_field: "phone" } %>
        </div>

        <div>
          <%= fd.label :notification_channel, "Canal de notificação" %>
          <%= fd.select :notification_channel, Driver::NOTIFICATION_CHANNELS,
                {}, data: { lookup_target: "fillable", lookup_field: "notification_channel" } %>
        </div>
      <% end %>
    </div>
  </fieldset>

  <fieldset>
    <legend>Caminhão</legend>
    <p>Informe a placa: se já estiver cadastrada, os demais dados serão carregados automaticamente.</p>
    <%= render "shared/errors", record: @truck, action_label: "cadastro do caminhão" %>
    <div data-controller="lookup"
         data-lookup-url-value="<%= lookup_registration_trucks_path %>"
         data-lookup-param-value="plate">
      <%= form.fields_for :truck, @truck do |ft| %>
        <div>
          <%= ft.label :plate, "Placa" %>
          <%= ft.text_field :plate, data: { lookup_target: "query", action: "blur->lookup#lookup" } %>
          <span class="spinner" data-lookup-target="spinner" hidden></span>
        </div>

        <div>
          <%= ft.label :model, "Modelo" %>
          <%= ft.text_field :model, data: { lookup_target: "fillable", lookup_field: "model" } %>
        </div>

        <div>
          <%= ft.label :capacity, "Capacidade" %>
          <%= ft.number_field :capacity, data: { lookup_target: "fillable", lookup_field: "capacity" } %>
        </div>
      <% end %>
    </div>
  </fieldset>

  <div class="button_to visit-sumbit">
    <%= form.submit "Registrar check-in" %>
  </div>
<% end %>

<h2>Pátio</h2>

<table>
  <thead>
    <tr>
      <th>Motorista</th>
      <th>Caminhão</th>
      <th>Entrada no pátio</th>
    </tr>
  </thead>
  <tbody>
    <% @yard_visits.each do |visit| %>
      <tr>
        <td><%= visit.driver.name %></td>
        <td><%= visit.truck.plate %></td>
        <td><%= visit.entered_yard_at.strftime("%d/%m/%Y %H:%M") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
